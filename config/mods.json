                    ]
                }
            ],
            "thunderstore": {
                "community": "chillwithyou",
                "namespace": "Small_tailqwq",
                "name": "RealTimeWeather",
                "description": "实时天气同步插件。",
                "dependencies": [
                    "BepInEx-BepInExPack-5.4.2304"
                ]
            },
            "package_files": {
