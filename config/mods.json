                "icon": "templates/realtime-weather/icon.png"
            }
        },
        {
            "key": "aichat",
            "enabled": true,
            "source": {
                "owner": "qzrs777",
                "repo": "AIChat"
            },
            "assets": [
                {
                    "matcher": "*.zip",
                    "kind": "zip",
                    "extract": [
                        {
                            "from": "BepInEx/plugins/*.dll",
                            "to": "BepInEx/plugins/"
                        },
                        {
                            "from": "plugins/*.dll",
                            "to": "BepInEx/plugins/"
                        },
                        {
                            "from": "*.dll",
                            "to": "BepInEx/plugins/"
                        }
                    ]
                }
            ],
            "thunderstore": {
                "community": "chillwithyou",
                "namespace": "qzrs777",
                "name": "AIChat",
                "description": "AI 聊天插件（zip 资产测试项）。",
