{
    "mods": [
        {
            "key": "igpu-savior",
            "enabled": true,
            "source": {
                "owner": "Small-tailqwq",
                "repo": "iGPUSaviorMod"
            },
            "assets": [
                {
                    "matcher": "*.dll",
                    "kind": "file",
                    "target": "BepInEx/plugins/"
                },
                {
                    "matcher": "*.zip",
                    "kind": "zip",
                    "preserve_unmatched": true,
                    "exclude": [
                        "BepInEx/*",
                        "manifest.json",
                        "README.md",
                        "icon.png",
                        "CHANGELOG.md",
                        "winhttp.dll",
                        "doorstop_config.ini"
                    ],
                    "extract": [
                        {
                            "from": "BepInEx/plugins/*.dll",
                            "to": "BepInEx/plugins/"
                        }
                    ]
                }
            ],
            "thunderstore": {
                "community": "chillwithyou",
                "namespace": "Small_tailqwq",
                "name": "iGPU_Savior",
                "description": "性能和体验优化插件。",
                "dependencies": [
                    "BepInEx-BepInExPack-5.4.2304"
                ]
            },
            "package_files": {
                "readme": "templates/igpu-savior/README.md",
                "icon": "templates/igpu-savior/icon.png"
            }
        },
        {
            "key": "realtime-weather",
            "enabled": true,
            "source": {
                "owner": "Small-tailqwq",
